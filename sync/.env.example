# REIN authentication — set REIN_AUTH_TYPE to whichever REIN provides
# Pick ONE of: 'reso' (modern OAuth2 + JSON OData) or 'rets' (legacy XML Digest)
REIN_AUTH_TYPE=reso

# REIN_BASE_URL: the OData endpoint root for RESO Web API
# (e.g., https://api.rein.example.com/RESO/OData)
REIN_BASE_URL=

# RESO Web API (OAuth2 client_credentials) — fill these if REIN_AUTH_TYPE=reso
REIN_CLIENT_ID=
REIN_CLIENT_SECRET=
REIN_TOKEN_URL=
REIN_SCOPE=

# Legacy RETS XML Digest — fill these if REIN_AUTH_TYPE=rets
REIN_USERNAME=
REIN_PASSWORD=
REIN_LOGIN_URL=
REIN_USER_AGENT=VaHomeSync/1.0
REIN_RETS_VERSION=RETS/1.7.2

# Resource/Class names per REIN's data dictionary (defaults are common conventions)
REIN_RESOURCE=Property
REIN_CLASS=Listing
REIN_PHOTO_RESOURCE=Property
REIN_PHOTO_CLASS=LargePhoto

# Photo cap per Exhibit A IDX (REIN typically allows up to 50)
MAX_PHOTOS_PER_LISTING=50

# Page size for paginated fetches
PAGE_SIZE=200

# Overlap window for incremental sync (minutes) — re-pull this many minutes
# of data on each incremental run to catch records that were modified
# during the previous run
INCREMENTAL_OVERLAP_MINUTES=5

# Supabase — service role key (server-side ONLY, never expose to client)
SUPABASE_URL=https://sudnlunconwkjntzkdjr.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Vercel Blob — token from Vercel dashboard → vahome-photos store → .env.local tab
BLOB_READ_WRITE_TOKEN=

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info
